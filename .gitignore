# Environment
.env
.venv
venv/
ENV/
env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Data directories
# NOTE: data/pdfs/ is NOT ignored — PDFs are committed to the repo so they
# survive Streamlit Community Cloud restarts (ephemeral filesystem).
data/processed/*.json
vectordb/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.kiro/

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
logs/
*.log

# Streamlit — config.toml is tracked; secrets.toml is not
.streamlit/secrets.toml

# Temporary files
tmp/
temp/
*.tmp

# ============================================
# UNNECESSARY FILES FOR STREAMLIT APP
# ============================================

# Documentation (not needed for app to run)
docs/
Project_Files/

# Testing files (not needed for app to run)
tests/
.pytest_cache/

# Utility scripts (optional)
scripts/deploy_page_wise_chunking.ps1
scripts/test_*.py
scripts/validate_metadata.py
scripts/verify_setup.py

# Analysis files
UNNECESSARY_FILES_ANALYSIS.txt
