# Data directories
# NOTE: data/pdfs/ is NOT ignored — PDFs are committed to the repo so they
# survive Streamlit Community Cloud restarts (ephemeral filesystem).
# data/processed/ - JSON files tracked for definitions
vectordb/

# IDE
.vscode/
.vs/
.idea/
*.swp
*.swo
*~
.kiro/

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
logs/
*.log

# Streamlit — config.toml is tracked; secrets.toml is not
.streamlit/secrets.toml

# Temporary files
tmp/
temp/
*.tmp

# ============================================
# UNNECESSARY FILES FOR STREAMLIT APP
# ============================================

# Documentation (not needed for app to run)
# docs/ - Now tracked for GitHub documentation
Project_Files/

# LLM response cache (auto-generated, per-machine)
data/cache/

# Vector database (auto-generated from PDFs, too large to track)
vectordb/

# Testing artifacts (keep .py test files for CI)
tests/__pycache__/
tests/*.txt
tests/*.json
tests/*.html
.pytest_cache/

# Utility scripts (optional)
scripts/deploy_page_wise_chunking.ps1
scripts/test_*.py
scripts/validate_metadata.py
scripts/verify_setup.py

# Analysis files
UNNECESSARY_FILES_ANALYSIS.txt
