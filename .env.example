# ─────────────────────────────────────────
# CLAUDE API
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.2

# ─────────────────────────────────────────
# EMBEDDING MODEL
# ─────────────────────────────────────────
# Options: sentence-transformers/all-MiniLM-L6-v2 (free, local)
#          text-embedding-3-small (OpenAI, paid)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ─────────────────────────────────────────
# VECTOR DATABASE
# ─────────────────────────────────────────
CHROMA_DB_PATH=./vectordb/chroma_db
CHROMA_COLLECTION_NAME=insurance_pd_reports

# ─────────────────────────────────────────
# CHUNKING SETTINGS
# ─────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MIN_CHUNK_SIZE=100

# ─────────────────────────────────────────
# RETRIEVAL SETTINGS
# ─────────────────────────────────────────
TOP_K_RESULTS=8
SIMILARITY_THRESHOLD=0.3

# ─────────────────────────────────────────
# PDF PROCESSING
# ─────────────────────────────────────────
PDF_INPUT_DIR=./data/pdfs
PROCESSED_OUTPUT_DIR=./data/processed

# ─────────────────────────────────────────
# COMPANY METADATA
# ─────────────────────────────────────────
# File naming convention: {COMPANY_CODE}_{QUARTER}_{FY}.pdf
# Example: HDFC_Life_Q1_FY25.pdf
COMPANY_CODES=LIC,HDFC_Life,SBI_Life,ICICI_Pru,Max_Life,Bajaj_Life,Kotak_Life,Tata_AIA

# ─────────────────────────────────────────
# STREAMLIT APP
# ─────────────────────────────────────────
APP_TITLE=Insurance PD Report Analyzer
APP_PORT=8501
MAX_UPLOAD_SIZE_MB=50
